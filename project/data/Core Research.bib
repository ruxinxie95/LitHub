@incollection{woodMaterialProgrammingBioinspired2023,
  title = {Material {{Programming}} for {{Bio-inspired}} and {{Bio-based Hygromorphic Building Envelopes}}},
  booktitle = {Advanced {{Materials}} in {{Smart Building Skins}} for {{Sustainability}}: {{From Nano}} to {{Macroscale}}},
