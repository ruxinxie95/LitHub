}

@article{renPlantMorphingStrategiesPlantInspired2021,
  title = {Plant-{{Morphing Strategies}} and {{Plant-Inspired Soft Actuators Fabricated}} by {{Biomimetic Four-Dimensional Printing}}: {{A Review}}},
  shorttitle = {Plant-{{Morphing Strategies}} and {{Plant-Inspired Soft Actuators Fabricated}} by {{Biomimetic Four-Dimensional Printing}}},
